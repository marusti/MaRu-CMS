        .contact-form {
            max-width: 700px;
            background: #fff;
            padding: 2em;
            border-radius: 8px;
            box-shadow: 0 0 10px #ddd;
            font-family: sans-serif;
        }
        .form-grid {
            display: flex;
            gap: 1em;
            flex-wrap: wrap;
        }
        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .full-width {
            width: 100%;
        }
        input[type="text"],
        input[type="email"],
        textarea {
            padding: 0.5em;
            border: 1px solid #ccc;
            border-radius: 4px;
            margin-top: 0.3em;
        }
        label {
            font-weight: bold;
        }
        .contact-success {
            background: #e0fbe4;
            color: #256029;
            padding: 1em;
            border: 1px solid #b2dfb4;
            border-radius: 6px;
            margin-bottom: 1em;
        }
        .contact-error {
            background: #ffe0e0;
            color: #8a1f1f;
            padding: 1em;
            border: 1px solid #e0b2b2;
            border-radius: 6px;
            margin-bottom: 1em;
        }
        .btn-submit {
            background: #0066cc;
            color: #fff;
            padding: 0.6em 1.2em;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-submit:hover {
            background: #0055aa;
        }
